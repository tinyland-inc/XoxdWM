# EXWM-VR udev rules
# Install to /etc/udev/rules.d/99-exwm-vr.rules
# Then run: sudo udevadm control --reload-rules && sudo udevadm trigger

# ── OpenBCI Cyton (FTDI FT231X) ─────────────────────────────────────
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6015", MODE="0666", GROUP="dialout", SYMLINK+="openbci"

# ── VR HMDs ──────────────────────────────────────────────────────────
# Valve (Index, Vive, Tundra Tracker) — USB + hidraw
SUBSYSTEM=="usb", ATTR{idVendor}=="28de", MODE="0666", GROUP="video"
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="28de", MODE="0660", GROUP="video", TAG+="uaccess"
# Oculus / Meta (Rift, Quest Link)
SUBSYSTEM=="usb", ATTR{idVendor}=="2833", MODE="0666", GROUP="video"
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="2833", MODE="0660", GROUP="video", TAG+="uaccess"
# HTC (Vive, Vive Pro)
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0bb4", MODE="0660", GROUP="video", TAG+="uaccess"

# ── Bigscreen Beyond (Beyond 1, 2, 2e) ──────────────────────────
# HMD HID interface (HID commands, proximity, IMU)
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="35bd", ATTRS{idProduct}=="0101", MODE="0660", GROUP="video", TAG+="uaccess"
# Bigeye eye tracking camera
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="35bd", ATTRS{idProduct}=="0202", MODE="0660", GROUP="video", TAG+="uaccess"
# Audio Strap
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="35bd", ATTRS{idProduct}=="0105", MODE="0660", GROUP="video", TAG+="uaccess"
# Firmware update mode (DFU)
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="35bd", ATTRS{idProduct}=="4004", MODE="0660", GROUP="video", TAG+="uaccess"
# USB device access (all Bigscreen devices)
SUBSYSTEM=="usb", ATTR{idVendor}=="35bd", MODE="0666"

# ── Beyond auto power-on ──────────────────────────────────────────
# When the Beyond HMD hidraw device appears, trigger the power-on service.
# The service sends the 5-packet HID wake sequence via beyond-power-on.
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="35bd", ATTRS{idProduct}=="0101", ACTION=="add", TAG+="systemd", ENV{SYSTEMD_WANTS}="exwm-vr-beyond-power.service"
