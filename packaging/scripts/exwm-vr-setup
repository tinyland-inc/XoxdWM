#!/bin/bash
# exwm-vr-setup — unified setup entrypoint for EXWM-VR hardware hosts
#
# Usage: exwm-vr-setup <command> [options]
#
# Commands:
#   prereqs          Install groups, udev rules, check firmware
#   kernel-upgrade   Install ELRepo kernel-ml + firmware update
#   sway-setup       Build + install sway host compositor
#   steam-setup      Install native Steam + configure SteamVR
#   monado-setup     Build + install Monado OpenXR runtime
#   verify           Verify display, DRM connectors, USB, permissions
#   beyond-status    Quick Beyond 2e hardware status
#   beyond-hid-test  Test HID device access
#   gpu-tools        Install Vulkan tools + GPU diagnostics
#   beyond-power-on  Send HID power-on sequence to Beyond display
#   beyond-display-init  Set DSC BPP + link rate + HID panel init (sudo)
#   beyond-monitor       Continuous display pipeline monitor (sudo)
#   beyond-dsc-flash     Toggle DSC to trigger FPGA re-init flash (sudo)
#   beyond-dsc-sweep     Try different DSC BPP values (sudo, destructive)
#   kernel-dsc-fix   Patch amdgpu DSC QP tables for Beyond (reboot needed)
#   full-setup       Run prereqs + kernel-upgrade (reboot needed after)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

# ── Helpers ─────────────────────────────────────────────

_need_root() {
    if [ "$(id -u)" -ne 0 ]; then
        echo "ERROR: This command requires root. Run with sudo."
        exit 1
    fi
}

_check_user() {
    local user="${EXWM_USER:-$(logname 2>/dev/null || echo "${SUDO_USER:-$USER}")}"
    echo "$user"
}

# ── Commands ────────────────────────────────────────────

cmd_prereqs() {
    _need_root
    local user
    user=$(_check_user)

    echo "=== EXWM-VR Prerequisites ==="
    echo "  User: $user"
    echo

    # Groups
    echo "[1/3] Adding $user to video, render, input groups..."
    usermod -aG video,render,input "$user"
    echo "  Done. Groups: $(id "$user")"
    echo

    # udev rules
    echo "[2/3] Installing udev rules..."
    local rules_src="$PROJECT_ROOT/packaging/udev/99-exwm-vr.rules"
    if [ -f "$rules_src" ]; then
        cp "$rules_src" /etc/udev/rules.d/99-exwm-vr.rules
    elif [ -f /tmp/99-exwm-vr.rules ]; then
        cp /tmp/99-exwm-vr.rules /etc/udev/rules.d/99-exwm-vr.rules
    else
        echo "  ERROR: udev rules not found at $rules_src"
        exit 1
    fi
    # Note: non_desktop is an immutable DRM property set by kernel EDID quirk
    # table (BIG/0x1234). Kernel 6.13+ handles this automatically — no udev
    # rule needed. The old 98-bigscreen-non-desktop.rules was a no-op.

    udevadm control --reload-rules
    udevadm trigger
    echo "  Installed: /etc/udev/rules.d/99-exwm-vr.rules"
    echo

    # Beyond power-on service
    local svc_src="$PROJECT_ROOT/packaging/systemd/exwm-vr-beyond-power.service"
    [ ! -f "$svc_src" ] && svc_src="/tmp/exwm-vr-beyond-power.service"
    if [ -f "$svc_src" ]; then
        cp "$svc_src" /etc/systemd/system/exwm-vr-beyond-power.service
        # Install beyond-power-on script
        mkdir -p /usr/libexec/exwm-vr
        local po_src="$PROJECT_ROOT/packaging/scripts/beyond-power-on"
        if [ -f "$po_src" ]; then
            cp "$po_src" /usr/libexec/exwm-vr/beyond-power-on
            chmod +x /usr/libexec/exwm-vr/beyond-power-on
        elif [ -f /tmp/beyond-power-on ]; then
            cp /tmp/beyond-power-on /usr/libexec/exwm-vr/beyond-power-on
            chmod +x /usr/libexec/exwm-vr/beyond-power-on
        fi
        systemctl daemon-reload
        echo "  Installed: exwm-vr-beyond-power.service"
    fi

    # Firmware check
    echo "[3/3] Checking amdgpu firmware..."
    if ls /lib/firmware/amdgpu/gc_12_0_0* >/dev/null 2>&1; then
        echo "  Found $(ls /lib/firmware/amdgpu/gc_12_0_0* | wc -l) gc_12_0_0 blobs"
    else
        echo "  WARNING: No gc_12_0_0 firmware found"
    fi
    echo

    echo "=== Prerequisites installed. Log out/in for groups to take effect. ==="
}

cmd_kernel_upgrade() {
    _need_root

    echo "=== Kernel Upgrade (ELRepo kernel-ml) ==="
    echo "  Current: $(uname -r)"
    echo

    # ELRepo
    echo "[1/4] Installing ELRepo..."
    if rpm -q elrepo-release >/dev/null 2>&1; then
        echo "  Already installed"
    else
        dnf install -y elrepo-release
    fi
    echo

    # kernel-ml
    echo "[2/4] Installing kernel-ml..."
    dnf --enablerepo=elrepo-kernel install -y \
        kernel-ml kernel-ml-devel kernel-ml-modules kernel-ml-modules-extra
    echo

    # Firmware
    echo "[3/4] Updating amdgpu firmware..."
    local fw_tmp
    fw_tmp=$(mktemp -d)
    git clone --depth 1 --filter=blob:none --sparse \
        https://git.kernel.org/pub/scm/linux/kernel/git/firmware/linux-firmware.git \
        "$fw_tmp/linux-firmware" 2>&1 | tail -1
    cd "$fw_tmp/linux-firmware"
    git sparse-checkout set amdgpu 2>/dev/null || true
    cp -u amdgpu/* /lib/firmware/amdgpu/ 2>/dev/null || cp amdgpu/* /lib/firmware/amdgpu/
    cd /
    rm -rf "$fw_tmp"

    local new_kver
    new_kver=$(rpm -q kernel-ml --qf '%{VERSION}-%{RELEASE}.%{ARCH}\n' | sort -V | tail -1)
    echo "  Rebuilding initramfs for $new_kver..."
    dracut --force "/boot/initramfs-${new_kver}.img" "$new_kver"
    echo

    # GRUB / BLS
    echo "[4/4] Configuring boot..."
    # Note: do NOT use video=DP-2:d — it disables the connector entirely,
    # preventing Monado/SteamVR from acquiring it via DRM lease.
    # non_desktop is handled by kernel EDID quirk table (BIG/0x1234).
    local vr_args="amdgpu.modeset=1 amdgpu.dc=1 amdgpu.dcdebugmask=0x10"
    # Update /etc/default/grub for future kernel installs
    if ! grep -q 'amdgpu.modeset=1' /etc/default/grub; then
        sed -i "s/GRUB_CMDLINE_LINUX=\"\(.*\)\"/GRUB_CMDLINE_LINUX=\"\1 $vr_args\"/" /etc/default/grub
    fi
    # BLS-enabled systems (Rocky 10+): grubby updates the actual boot entry
    grubby --update-kernel="/boot/vmlinuz-$new_kver" --args="$vr_args"
    grubby --set-default="/boot/vmlinuz-$new_kver"
    echo "  Default boot: $new_kver"
    echo "  Args added: $vr_args"
    echo

    # Note: non_desktop is an immutable DRM property handled by kernel EDID
    # quirk table — no udev rule needed for kernels >= 6.13.
    udevadm control --reload-rules
    echo

    echo "=== Kernel upgrade complete. REBOOT REQUIRED: sudo reboot ==="
}

cmd_verify() {
    echo "=== EXWM-VR Display Verification ==="
    echo

    # Kernel
    echo "[kernel] $(uname -r)"
    local kmin
    kmin=$(uname -r | cut -d. -f2)
    [ "$kmin" -ge 13 ] 2>/dev/null && echo "  OK (>= 6.13)" || echo "  WARNING (< 6.13)"
    echo

    # DRM connectors
    echo "[drm]"
    local found_beyond=false
    for conn in /sys/class/drm/card*-*/; do
        [ -d "$conn" ] || continue
        local name status nd
        name=$(basename "$conn")
        status=$(cat "$conn/status" 2>/dev/null || echo "?")
        nd=$(cat "$conn/non_desktop" 2>/dev/null || echo "?")
        echo "  $name: status=$status non_desktop=$nd"
        if [ "$status" = "connected" ] && [ "$nd" = "1" ]; then
            found_beyond=true
        fi
    done
    echo

    # USB
    echo "[usb]"
    lsusb 2>/dev/null | grep -i "35bd\|bigscreen\|bigeye" || echo "  No Beyond USB devices"
    echo

    # hidraw
    echo "[hidraw]"
    for h in /dev/hidraw*; do
        [ -c "$h" ] || continue
        local perms hnum name
        hnum=$(basename "$h")
        perms=$(stat -c '%a %U:%G' "$h")
        name=$(grep HID_NAME "/sys/class/hidraw/$hnum/device/uevent" 2>/dev/null | cut -d= -f2 || echo "?")
        echo "  $h: $perms ($name)"
    done
    echo

    # EDID
    echo "[edid]"
    for conn in /sys/class/drm/card*-DP-*/; do
        [ -d "$conn" ] || continue
        local name status
        name=$(basename "$conn")
        status=$(cat "$conn/status" 2>/dev/null)
        if [ "$status" = "connected" ] && [ -f "$conn/edid" ]; then
            local size
            size=$(xxd "$conn/edid" 2>/dev/null | wc -l)
            if [ "$size" -gt 0 ]; then
                echo "  $name: EDID present ($(( size * 16 )) bytes)"
                strings "$conn/edid" 2>/dev/null | head -3 | sed 's/^/    /'
            fi
        fi
    done
    echo

    # Modes
    echo "[modes]"
    for conn in /sys/class/drm/card*-DP-*/; do
        [ -d "$conn" ] || continue
        local name status modes
        name=$(basename "$conn")
        status=$(cat "$conn/status" 2>/dev/null)
        if [ "$status" = "connected" ]; then
            modes=$(cat "$conn/modes" 2>/dev/null)
            [ -n "$modes" ] && echo "  $name: $modes" | head -5
        fi
    done
    echo

    if $found_beyond; then
        echo "PASS: Beyond detected as non-desktop display"
    else
        echo "INCOMPLETE: No non-desktop display found"
        echo "  Check: kernel version, EDID quirk, cable connection"
    fi
}

cmd_beyond_status() {
    echo "=== Beyond 2e Quick Status ==="
    echo
    echo "[usb]"
    lsusb 2>/dev/null | grep -i "35bd\|bigscreen\|bigeye" || echo "  Not detected"
    echo
    echo "[drm]"
    for c in /sys/class/drm/card*-DP-*/; do
        [ -d "$c" ] || continue
        local n s nd
        n=$(basename "$c")
        s=$(cat "$c/status" 2>/dev/null)
        nd=$(cat "$c/non_desktop" 2>/dev/null)
        echo "  $n: status=$s non_desktop=$nd"
    done
    echo
    echo "[hidraw]"
    for h in /dev/hidraw*; do
        [ -c "$h" ] || continue
        local hnum name perms
        hnum=$(basename "$h")
        name=$(grep HID_NAME "/sys/class/hidraw/$hnum/device/uevent" 2>/dev/null | cut -d= -f2)
        [ -z "$name" ] && continue
        perms=$(stat -c '%a' "$h")
        echo "  $h: $name (mode=$perms)"
    done
}

cmd_beyond_hid_test() {
    echo "=== Beyond HID Access Test ==="
    for i in $(seq 0 9); do
        local path="/dev/hidraw$i"
        [ -c "$path" ] || continue
        local name
        name=$(grep HID_NAME "/sys/class/hidraw/hidraw$i/device/uevent" 2>/dev/null | cut -d= -f2)
        [ -z "$name" ] && continue
        echo -n "  $path ($name): "
        if python3 -c "
import os
fd = os.open('$path', os.O_RDWR)
os.close(fd)
print('OK')
" 2>/dev/null; then
            true
        else
            echo "PERMISSION DENIED"
        fi
    done
}

cmd_gpu_tools() {
    _need_root

    echo "=== GPU Diagnostic Tools ==="
    echo

    echo "[1/3] Installing Vulkan tools..."
    dnf install -y vulkan-tools mesa-vulkan-drivers vulkan-loader 2>&1 | tail -5
    echo

    echo "[2/3] Installing DRM utilities..."
    dnf install -y libdrm-utils 2>&1 | tail -5 || \
        echo "  libdrm-utils not available (optional)"
    echo

    echo "[3/3] Verifying..."
    if command -v vulkaninfo >/dev/null 2>&1; then
        echo "  vulkaninfo: $(command -v vulkaninfo)"
        vulkaninfo --summary 2>&1 | head -10
    else
        echo "  WARNING: vulkaninfo still not available after install"
    fi
    echo
    echo "=== GPU tools installed ==="
}

cmd_sway_setup() {
    _need_root
    local user
    user=$(_check_user)

    echo "=== Sway Host Compositor Setup ==="
    echo "  Building sway 1.10 (wlroots 0.18) for VR development."
    echo "  Sway manages the desktop monitor; VR HMD is DRM-leased to Monado."
    echo

    # Disable broken third-party repos that block dnf
    for repo in runner_gitlab-runner runner_gitlab-runner-source tailscale-stable; do
        dnf config-manager --disable "$repo" 2>/dev/null || true
    done

    # Build dependencies (core)
    echo "[1/5] Installing build dependencies..."
    dnf install -y \
        wlroots-devel wayland-devel wayland-protocols-devel \
        libinput-devel libevdev-devel pixman-devel \
        mesa-libEGL-devel mesa-libGLES-devel \
        libdrm-devel json-c-devel pango-devel cairo-devel pcre2-devel \
        meson ninja-build gcc scdoc \
        seatd xorg-x11-server-Xwayland 2>&1 | tail -5
    # Terminal + launcher (from EPEL)
    # Note: nix-packaged terminals (alacritty, ghostty) fail on non-NixOS due
    # to Wayland/GL library mismatches. System-packaged kitty works correctly.
    dnf install -y epel-release 2>&1 | tail -2
    if ! command -v kitty >/dev/null 2>&1; then
        dnf install -y kitty 2>/dev/null && echo "  kitty installed" || \
            { echo "  WARNING: kitty not available, falling back to xterm"; dnf install -y xterm 2>&1 | tail -2; }
    fi
    if ! command -v dmenu-wl_run >/dev/null 2>&1; then
        dnf install -y dmenu-wayland 2>/dev/null && echo "  dmenu-wayland installed" || \
            echo "  WARNING: dmenu-wayland not available"
    fi
    echo

    # Enable and start seatd
    echo "[2/5] Configuring seatd..."
    systemctl enable --now seatd.service 2>/dev/null || true
    usermod -aG seat "$user" 2>/dev/null || true
    echo "  seatd: $(systemctl is-active seatd.service 2>/dev/null || echo 'not running')"
    echo

    # Build wlroots from source with Bigscreen Beyond non_desktop patch
    # The patch forces non_desktop=true for Bigscreen Beyond headsets even
    # on kernels that lack the EDID quirk (BIG/0x1234). Without it, Sway
    # won't offer DP-2 for DRM lease and Monado can't acquire the display.
    local wlroots_ver="0.18.2"
    local wlroots_dir="/tmp/wlroots-build"
    echo "[3/6] Building patched wlroots $wlroots_ver..."
    # Ensure XWayland dev headers are available (sway needs wlr_xwayland_create)
    dnf install -y xorg-x11-server-Xwayland-devel hwdata-devel 2>&1 | tail -3
    rm -rf "$wlroots_dir"
    git clone --depth 1 --branch "$wlroots_ver" \
        https://gitlab.freedesktop.org/wlroots/wlroots.git "$wlroots_dir" 2>&1 | tail -1
    cd "$wlroots_dir"

    # Apply Bigscreen Beyond non_desktop patch
    local patch_src="$SCRIPT_DIR/../patches/wlroots-bigscreen-non-desktop.patch"
    [ ! -f "$patch_src" ] && patch_src="$PROJECT_ROOT/patches/wlroots-bigscreen-non-desktop.patch"
    [ ! -f "$patch_src" ] && patch_src="/tmp/wlroots-bigscreen-non-desktop.patch"
    if [ -f "$patch_src" ]; then
        git apply "$patch_src" 2>/dev/null || patch -p1 < "$patch_src" 2>/dev/null || \
            echo "  WARNING: patch failed to apply (may already be applied or version mismatch)"
        echo "  Applied: wlroots-bigscreen-non-desktop.patch"
    else
        echo "  WARNING: wlroots patch not found — non_desktop detection may not work"
        echo "  Expected at: $PROJECT_ROOT/patches/wlroots-bigscreen-non-desktop.patch"
    fi

    meson setup build --prefix=/usr/local -Dbuildtype=release -Dxwayland=enabled 2>&1 | tail -3
    ninja -C build -j"$(nproc)" 2>&1 | tail -3
    ninja -C build install 2>&1 | tail -3
    ldconfig
    cd /
    rm -rf "$wlroots_dir"
    echo "  Installed: patched wlroots $wlroots_ver"
    echo

    # Build sway (1.10 for wlroots 0.18; DRM lease since 1.7)
    local sway_ver="1.10"
    local build_dir="/tmp/sway-build"
    echo "[4/6] Building sway $sway_ver..."
    rm -rf "$build_dir"
    git clone --depth 1 --branch "$sway_ver" \
        https://github.com/swaywm/sway.git "$build_dir" 2>&1 | tail -1
    cd "$build_dir"
    meson setup build --prefix=/usr/local -Dbuildtype=release 2>&1 | tail -3
    ninja -C build -j"$(nproc)" 2>&1 | tail -3
    ninja -C build install 2>&1 | tail -3
    cd /
    rm -rf "$build_dir"
    echo "  Installed: $(sway --version 2>/dev/null || echo 'ERROR')"
    echo

    # Build xdg-desktop-portal-wlr (screenshot/screencast portals for sway)
    # NOTE: This does NOT provide DRM lease pass-through. DRM lease works
    # natively through sway's wlr-drm-lease-v1 protocol — but only with
    # native Steam. Flatpak Steam's pressure-vessel proxy filters it out.
    echo "[5/7] Building xdg-desktop-portal-wlr..."
    local portal_ver="0.7.1"
    if ! command -v xdg-desktop-portal-wlr >/dev/null 2>&1; then
        dnf install -y inih-devel systemd-devel pipewire-devel 2>&1 | tail -3
        local portal_dir="/tmp/xdpw-build"
        rm -rf "$portal_dir"
        git clone --depth 1 --branch "v$portal_ver" \
            https://github.com/emersion/xdg-desktop-portal-wlr.git "$portal_dir" 2>&1 | tail -1
        cd "$portal_dir"
        meson setup build --prefix=/usr/local -Dbuildtype=release 2>&1 | tail -3
        ninja -C build -j"$(nproc)" 2>&1 | tail -3
        ninja -C build install 2>&1 | tail -3
        cd /
        rm -rf "$portal_dir"
        echo "  Installed: $(command -v xdg-desktop-portal-wlr 2>/dev/null || echo 'ERROR')"
        # Register as the portal backend for sway
        mkdir -p /usr/share/xdg-desktop-portal
        cat > /usr/share/xdg-desktop-portal/sway-portals.conf <<'PORTAL'
[preferred]
default=gtk
org.freedesktop.impl.portal.Screenshot=wlr
org.freedesktop.impl.portal.ScreenCast=wlr
PORTAL
    else
        echo "  xdg-desktop-portal-wlr already installed"
    fi
    echo

    # Install config
    echo "[6/7] Installing sway config..."
    local cfg_dir="/home/$user/.config/sway"
    mkdir -p "$cfg_dir"
    local cfg_src="$SCRIPT_DIR/../sway/config"
    [ ! -f "$cfg_src" ] && cfg_src="$PROJECT_ROOT/packaging/sway/config"
    [ ! -f "$cfg_src" ] && cfg_src="/tmp/exwm-sway-config"
    if [ -f "$cfg_src" ]; then
        cp "$cfg_src" "$cfg_dir/config"
        # Status bar script
        local status_src="${cfg_src%config}status.sh"
        [ ! -f "$status_src" ] && status_src="/tmp/exwm-sway-status.sh"
        if [ -f "$status_src" ]; then
            cp "$status_src" "$cfg_dir/status.sh"
            chmod +x "$cfg_dir/status.sh"
        fi
        chown -R "$user:$user" "$cfg_dir"
        echo "  Installed: $cfg_dir/config"
    else
        echo "  WARNING: sway config template not found"
    fi
    echo

    # Verify
    echo "[7/7] Verifying..."
    echo "  sway: $(command -v sway 2>/dev/null || echo 'NOT FOUND')"
    echo "  seatd: $(systemctl is-active seatd.service 2>/dev/null)"
    echo "  Xwayland: $(command -v Xwayland 2>/dev/null || echo 'NOT FOUND')"
    echo "  terminal: $(command -v kitty 2>/dev/null || command -v xterm 2>/dev/null || echo 'NOT FOUND')"
    echo "  portal-wlr: $(command -v xdg-desktop-portal-wlr 2>/dev/null || echo 'NOT FOUND')"
    echo
    echo "=== Sway setup complete ==="
    echo "  Start from TTY: sway"
    echo "  Install Steam: exwm-vr-setup steam-setup"
}

cmd_steam_setup() {
    _need_root
    local user
    user=$(_check_user)

    echo "=== Native Steam + SteamVR Setup ==="
    echo "  IMPORTANT: Flatpak Steam breaks DRM leasing (pressure-vessel"
    echo "  Wayland proxy filters wp_drm_lease_device_v1). Native RPM required."
    echo

    # Disable broken repos
    for repo in runner_gitlab-runner runner_gitlab-runner-source tailscale-stable; do
        dnf config-manager --disable "$repo" 2>/dev/null || true
    done

    # Install EPEL + RPM Fusion (nonfree for Steam)
    echo "[1/5] Installing repositories..."
    dnf install -y epel-release 2>&1 | tail -3
    local rhel_ver
    rhel_ver=$(rpm -E %rhel)
    dnf install -y \
        "https://mirrors.rpmfusion.org/free/el/rpmfusion-free-release-${rhel_ver}.noarch.rpm" \
        "https://mirrors.rpmfusion.org/nonfree/el/rpmfusion-nonfree-release-${rhel_ver}.noarch.rpm" \
        2>&1 | tail -3 || echo "  RPM Fusion may already be installed"
    echo

    # 32-bit compat libraries (Steam client is 32-bit)
    echo "[2/5] Installing 32-bit compatibility libraries..."
    dnf install -y \
        glibc.i686 libstdc++.i686 libX11.i686 libXext.i686 \
        mesa-libGL.i686 mesa-dri-drivers.i686 \
        alsa-lib.i686 pulseaudio-libs.i686 \
        nss.i686 nspr.i686 \
        libcurl.i686 openssl-libs.i686 2>&1 | tail -5
    echo

    # Install Steam
    echo "[3/5] Installing Steam..."
    dnf install -y steam 2>&1 | tail -5
    echo "  steam: $(command -v steam 2>/dev/null || echo 'NOT FOUND')"
    echo

    # Remove flatpak Steam if present (can't coexist cleanly)
    if flatpak info com.valvesoftware.Steam >/dev/null 2>&1; then
        echo "  NOTE: Flatpak Steam is still installed."
        echo "  Remove it to avoid confusion: flatpak uninstall com.valvesoftware.Steam"
    fi

    # Patch SteamVR if already installed
    echo "[4/5] Configuring SteamVR..."
    local steam_dir="/home/$user/.local/share/Steam"
    local steamvr_dir="$steam_dir/steamapps/common/SteamVR"
    if [ -d "$steamvr_dir" ]; then
        # CAP_SYS_NICE on vrcompositor-launcher
        local vrc="$steamvr_dir/bin/linux64/vrcompositor-launcher"
        if [ -f "$vrc" ]; then
            setcap CAP_SYS_NICE+ep "$vrc" 2>/dev/null && \
                echo "  CAP_SYS_NICE set on vrcompositor-launcher"
        fi
        # Patch SDL_VIDEODRIVER to wayland (SteamVR defaults to x11 which blocks DRM lease)
        local vrl="$steamvr_dir/bin/linux64/vrcompositor-launcher.sh"
        if [ -f "$vrl" ]; then
            sed -i 's/export SDL_VIDEODRIVER=x11/export SDL_VIDEODRIVER=wayland/' "$vrl" 2>/dev/null
            echo "  Patched SDL_VIDEODRIVER=wayland in vrcompositor-launcher.sh"
        fi
    else
        echo "  SteamVR not yet installed."
        echo "  Run Steam, install SteamVR, then re-run: exwm-vr-setup steam-setup"
    fi
    echo

    # Verify
    echo "[5/5] Verifying..."
    echo "  steam: $(command -v steam 2>/dev/null || echo 'NOT FOUND')"
    if [ -d "$steamvr_dir" ]; then
        echo "  SteamVR: $steamvr_dir"
    else
        echo "  SteamVR: not installed yet (install via Steam)"
    fi
    echo

    echo "=== Steam setup complete ==="
    echo "  Launch: steam (from sway terminal)"
    echo "  SteamVR: Install via Steam → Library → Tools → SteamVR"
    echo "  After SteamVR install, re-run: exwm-vr-setup steam-setup"
}

cmd_monado_setup() {
    _need_root
    local user
    user=$(_check_user)

    echo "=== Monado OpenXR Runtime Setup ==="
    echo

    # Disable broken repos
    for repo in runner_gitlab-runner runner_gitlab-runner-source tailscale-stable; do
        dnf config-manager --disable "$repo" 2>/dev/null || true
    done

    # Build dependencies
    echo "[1/4] Installing build dependencies..."
    dnf install -y \
        cmake ninja-build gcc-c++ \
        eigen3-devel libusb1-devel libuvc-devel \
        mesa-libEGL-devel mesa-libGL-devel mesa-vulkan-drivers vulkan-headers vulkan-loader-devel \
        wayland-devel wayland-protocols-devel libdrm-devel \
        hidapi-devel libXrandr-devel glslang glslang-devel \
        spirv-tools spirv-tools-devel opencv-devel libudev-devel 2>&1 | tail -5
    echo

    # Build Monado
    local build_dir="/tmp/monado-build"
    echo "[2/4] Building Monado..."
    if [ -f /usr/local/bin/monado-cli ]; then
        echo "  Monado already installed at /usr/local/bin/monado-cli"
        echo "  Rebuilding to ensure latest version..."
    fi
    rm -rf "$build_dir"
    git clone --depth 1 \
        https://gitlab.freedesktop.org/monado/monado.git "$build_dir" 2>&1 | tail -1
    cd "$build_dir"
    cmake -B build -G Ninja \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DCMAKE_BUILD_TYPE=RelWithDebInfo \
        -DXRT_BUILD_DRIVER_STEAMVR_LIGHTHOUSE=ON 2>&1 | tail -5
    ninja -C build -j"$(nproc)" 2>&1 | tail -3
    ninja -C build install 2>&1 | tail -3
    cd /
    rm -rf "$build_dir"
    echo

    # Set capabilities
    echo "[3/4] Setting capabilities..."
    if [ -f /usr/local/bin/monado-service ]; then
        setcap CAP_SYS_NICE=eip /usr/local/bin/monado-service
        echo "  CAP_SYS_NICE set on monado-service"
    fi
    echo

    # Install Monado environment config
    echo "[4/4] Installing Monado configuration..."
    local monado_cfg="/home/$user/.config/monado"
    mkdir -p "$monado_cfg"
    cat > "$monado_cfg/env" << 'ENVEOF'
# Monado environment for Bigscreen Beyond under Sway
# Source this before running monado-service or monado-cli.

# Force Wayland DRM lease target (not X11, not direct)
export XRT_COMPOSITOR_FORCE_WAYLAND=1

# Request lease of the Beyond HMD connector
export XRT_COMPOSITOR_WAYLAND_CONNECTOR=DP-2

# Enable SteamVR Lighthouse driver (for Beyond tracking)
export STEAMVR_LH_ENABLE=1

# Compute compositor (required for some AMD configurations)
export XRT_COMPOSITOR_COMPUTE=1

# IPD override (Beyond 2e has mechanical IPD, but Monado needs a hint)
export LH_OVERRIDE_IPD_MM=64
ENVEOF
    chown -R "$user:$user" "$monado_cfg"
    echo "  Installed: $monado_cfg/env"
    echo "  Usage: source ~/.config/monado/env && monado-service"
    echo

    echo "=== Monado setup complete ==="
    echo "  Probe: monado-cli probe"
    echo "  Service: source ~/.config/monado/env && monado-service"
}

cmd_beyond_power_on() {
    echo "=== Beyond Display Power-On ==="
    local script
    if [ -f "$PROJECT_ROOT/packaging/scripts/beyond-power-on" ]; then
        script="$PROJECT_ROOT/packaging/scripts/beyond-power-on"
    elif [ -f /tmp/beyond-power-on ]; then
        script="/tmp/beyond-power-on"
    elif [ -f "$SCRIPT_DIR/beyond-power-on" ]; then
        script="$SCRIPT_DIR/beyond-power-on"
    else
        echo "ERROR: beyond-power-on script not found"
        exit 1
    fi
    python3 "$script" "$@"
}

cmd_beyond_first_frame() {
    echo "=== Beyond First Frame Test ==="
    echo "  Validates the full DRM lease + Monado + OpenXR pipeline"
    echo "  by running hello_xr to display a test scene in the headset."
    echo

    # 1. Power on Beyond
    echo "[1/4] Powering on Beyond display..."
    cmd_beyond_power_on 2>/dev/null || echo "  WARNING: power-on failed (may already be on)"
    sleep 2
    echo

    # 2. Verify non_desktop connector
    echo "[2/4] Checking DRM connectors..."
    local found_nd=false
    for c in /sys/class/drm/card*-DP-*/; do
        [ -d "$c" ] || continue
        local n s nd
        n=$(basename "$c")
        s=$(cat "$c/status" 2>/dev/null)
        nd=$(cat "$c/non_desktop" 2>/dev/null)
        echo "  $n: status=$s non_desktop=$nd"
        if [ "$s" = "connected" ] && [ "$nd" = "1" ]; then
            found_nd=true
        fi
    done
    if ! $found_nd; then
        echo "  ERROR: No non_desktop connector found. Check kernel EDID quirk."
        exit 1
    fi
    echo

    # 3. Start monado-service in background
    echo "[3/4] Starting monado-service..."
    local monado_env="$HOME/.config/monado/env"
    if [ -f "$monado_env" ]; then
        set -a; source "$monado_env"; set +a
    else
        echo "  WARNING: $monado_env not found, using defaults"
        export XRT_COMPOSITOR_FORCE_WAYLAND=1
        export STEAMVR_LH_ENABLE=1
    fi

    # Kill any existing monado-service
    pkill -f monado-service 2>/dev/null || true
    sleep 1

    monado-service &
    local monado_pid=$!
    sleep 3

    if ! kill -0 "$monado_pid" 2>/dev/null; then
        echo "  ERROR: monado-service exited prematurely"
        echo "  Check: monado-cli probe"
        exit 1
    fi
    echo "  monado-service running (PID $monado_pid)"
    echo

    # 4. Run hello_xr
    echo "[4/4] Running hello_xr test..."
    local hello_xr=""
    for candidate in \
        /usr/local/bin/hello_xr \
        /tmp/openxr-build/build/src/tests/hello_xr/hello_xr \
        "$HOME/bin/hello_xr"; do
        if [ -x "$candidate" ]; then
            hello_xr="$candidate"
            break
        fi
    done

    if [ -z "$hello_xr" ]; then
        echo "  hello_xr not found. Build it first:"
        echo "    exwm-vr-setup openxr-build"
        kill "$monado_pid" 2>/dev/null
        exit 1
    fi

    echo "  Running: $hello_xr -G Vulkan2 (30s timeout)"
    # Pipe sleep to stdin: hello_xr reads stdin for key events and exits on
    # EOF, which happens immediately over SSH without a proper terminal.
    XR_RUNTIME_JSON="${XR_RUNTIME_JSON:-/usr/local/share/openxr/1/openxr_monado.json}" \
        timeout 30 bash -c "sleep 30 | $hello_xr -G Vulkan2" 2>&1 | tail -20
    local rc=$?

    # Cleanup
    kill "$monado_pid" 2>/dev/null
    wait "$monado_pid" 2>/dev/null

    echo
    if [ $rc -eq 0 ]; then
        echo "PASS: hello_xr completed successfully — first frame confirmed!"
    elif [ $rc -eq 124 ]; then
        echo "PASS: hello_xr ran for 30 seconds (timeout) — frames were being submitted"
    else
        echo "FAIL: hello_xr exited with code $rc"
        echo "  Debug: XR_RUNTIME_JSON=$XR_RUNTIME_JSON monado-cli probe"
    fi
}

cmd_openxr_build() {
    echo "=== Build hello_xr from OpenXR-SDK-Source ==="
    echo

    # Dependencies
    echo "[1/3] Checking build dependencies..."
    if command -v cmake >/dev/null 2>&1 && command -v ninja >/dev/null 2>&1; then
        echo "  cmake + ninja: OK"
    else
        echo "  Installing cmake + ninja..."
        sudo dnf install -y cmake ninja-build gcc-c++ 2>&1 | tail -3
    fi

    # Vulkan SDK headers
    if ! pkg-config --exists vulkan 2>/dev/null; then
        echo "  Installing Vulkan development headers..."
        sudo dnf install -y vulkan-headers vulkan-loader-devel 2>&1 | tail -3
    fi
    echo

    # Clone and build
    local build_dir="/tmp/openxr-build"
    echo "[2/3] Building hello_xr..."
    rm -rf "$build_dir"
    git clone --depth 1 https://github.com/KhronosGroup/OpenXR-SDK-Source.git "$build_dir" 2>&1 | tail -1
    cd "$build_dir"
    cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=Release 2>&1 | tail -5
    ninja -C build hello_xr 2>&1 | tail -5
    echo

    # Install
    echo "[3/3] Installing..."
    local hello_xr="$build_dir/build/src/tests/hello_xr/hello_xr"
    if [ -x "$hello_xr" ]; then
        sudo cp "$hello_xr" /usr/local/bin/hello_xr
        echo "  Installed: /usr/local/bin/hello_xr"
    else
        echo "  ERROR: hello_xr binary not found after build"
        exit 1
    fi
    echo

    echo "=== hello_xr built and installed ==="
    echo "  Test: exwm-vr-setup beyond-first-frame"
}

cmd_beyond_download_config() {
    echo "=== Beyond Calibration Config Download ==="
    echo "  Downloads lens distortion, IPD, display geometry, and color"
    echo "  calibration from the Beyond headset via lighthouse_console."
    echo

    # Find lighthouse_console
    local lhc=""
    for candidate in \
        "$HOME/.steam/steam/steamapps/common/SteamVR/tools/lighthouse/bin/linux64/lighthouse_console" \
        /usr/local/bin/lighthouse_console \
        "$HOME/bin/lighthouse_console"; do
        if [ -x "$candidate" ]; then
            lhc="$candidate"
            break
        fi
    done

    if [ -z "$lhc" ]; then
        echo "  ERROR: lighthouse_console not found"
        echo "  Install SteamVR: exwm-vr-setup steam-setup"
        echo "  Or copy from a SteamVR install:"
        echo "    SteamVR/tools/lighthouse/bin/linux64/lighthouse_console"
        exit 1
    fi
    echo "  lighthouse_console: $lhc"

    # Detect Beyond serial number
    echo "[1/3] Detecting Beyond serial number..."
    local serial=""
    serial=$("$lhc" 2>/dev/null | grep -oP 'LHR-[A-Z0-9]+|XCNL[A-Z0-9]+' | head -1)
    if [ -z "$serial" ]; then
        echo "  WARNING: Could not auto-detect serial. Trying all devices..."
        "$lhc" 2>&1 | head -10
    fi
    echo "  Serial: ${serial:-unknown}"
    echo

    # Download config
    local config_dir="$HOME/.config/monado"
    mkdir -p "$config_dir"
    local config_file="$config_dir/beyond-config.json"

    echo "[2/3] Downloading calibration config..."
    if [ -f "$config_file" ]; then
        cp "$config_file" "${config_file}.bak"
        echo "  Backed up existing: ${config_file}.bak"
    fi

    if [ -n "$serial" ]; then
        "$lhc" downloadconfig "$serial" > "$config_file" 2>&1
    else
        "$lhc" downloadconfig > "$config_file" 2>&1
    fi

    if [ -s "$config_file" ]; then
        echo "  Saved: $config_file ($(wc -c < "$config_file") bytes)"
    else
        echo "  ERROR: Config download produced empty file"
        rm -f "$config_file"
        exit 1
    fi
    echo

    # Parse key values
    echo "[3/3] Config summary..."
    if command -v python3 >/dev/null 2>&1; then
        python3 -c "
import json, sys
try:
    cfg = json.load(open('$config_file'))
    print(f'  Device: {cfg.get(\"device_class\", \"unknown\")}')
    print(f'  Serial: {cfg.get(\"device_serial_number\", \"unknown\")}')
    if 'device_measurements' in cfg:
        m = cfg['device_measurements']
        print(f'  IPD: {m.get(\"ipd\", \"?\")} mm')
    if 'tracking_to_eye_transform' in cfg:
        print(f'  Eye transforms: present ({len(cfg[\"tracking_to_eye_transform\"])} entries)')
except Exception as e:
    print(f'  (Could not parse config: {e})')
" 2>/dev/null || echo "  (python3 not available for parsing)"
    fi
    echo

    echo "=== Calibration config downloaded ==="
    echo "  Config: $config_file"
    echo "  Next: configure Monado IPD from this config"
}

cmd_beyond_oobe() {
    echo "=== Beyond Out-of-Box Experience ==="
    echo "  Full OOBE: power on → config → Monado → compositor → calibration"
    echo

    # Step 1: Power on
    echo "[1/5] Powering on Beyond..."
    cmd_beyond_power_on 2>/dev/null || echo "  (may already be on)"
    sleep 2
    echo

    # Step 2: Download config if not present
    echo "[2/5] Checking calibration config..."
    local config_file="$HOME/.config/monado/beyond-config.json"
    if [ -f "$config_file" ]; then
        echo "  Config present: $config_file"
    else
        echo "  Downloading calibration config..."
        cmd_beyond_download_config
    fi
    echo

    # Step 3: Start Monado
    echo "[3/5] Starting Monado..."
    local monado_env="$HOME/.config/monado/env"
    if [ -f "$monado_env" ]; then
        set -a; source "$monado_env"; set +a
    fi
    pkill -f monado-service 2>/dev/null || true
    sleep 1
    monado-service &
    local monado_pid=$!
    sleep 3
    if ! kill -0 "$monado_pid" 2>/dev/null; then
        echo "  ERROR: monado-service failed to start"
        exit 1
    fi
    echo "  Monado running (PID $monado_pid)"
    echo

    # Step 4: Check eye tracking cameras
    echo "[4/5] Checking eye tracking..."
    if lsusb 2>/dev/null | grep -q "35bd:0202"; then
        echo "  Bigeye camera detected (35bd:0202)"
        echo "  Eye tracking calibration will run after compositor starts"
    else
        echo "  Bigeye camera not detected — skipping eye tracking"
    fi
    echo

    # Step 5: Run first frame test
    echo "[5/5] Testing first frame..."
    local hello_xr=""
    for candidate in /usr/local/bin/hello_xr "$HOME/bin/hello_xr"; do
        [ -x "$candidate" ] && hello_xr="$candidate" && break
    done
    if [ -n "$hello_xr" ]; then
        XR_RUNTIME_JSON="${XR_RUNTIME_JSON:-/usr/local/share/openxr/1/openxr_monado.json}" \
            timeout 10 "$hello_xr" -G Vulkan2 2>&1 | tail -5
        echo "  First frame test complete"
    else
        echo "  hello_xr not available — build with: exwm-vr-setup openxr-build"
    fi

    # Cleanup
    kill "$monado_pid" 2>/dev/null
    wait "$monado_pid" 2>/dev/null
    echo

    echo "=== OOBE complete ==="
    echo "  Next steps:"
    echo "    1. Start compositor: ewwm-compositor --backend drm"
    echo "    2. Eye calibration: triggered automatically if Bigeye detected"
}

cmd_kernel_dsc_fix() {
    _need_root
    local kver
    kver=$(uname -r)
    local amdgpu_mod="/lib/modules/${kver}/kernel/drivers/gpu/drm/amd/amdgpu/amdgpu.ko.xz"

    echo "=== DSC QP Table Fix for Bigscreen Beyond ==="
    echo "  Kernel: $kver"
    echo "  Module: $amdgpu_mod"
    echo

    if [ ! -f "$amdgpu_mod" ]; then
        echo "ERROR: amdgpu module not found at $amdgpu_mod"
        exit 1
    fi

    # 1. Extract and back up original module
    echo "[1/4] Extracting module..."
    local orig_ko="/tmp/amdgpu-orig.ko"
    local patched_ko="/tmp/amdgpu-dsc-patched.ko"
    if [ ! -f "${amdgpu_mod}.orig" ]; then
        cp "$amdgpu_mod" "${amdgpu_mod}.orig"
        echo "  Backed up original to ${amdgpu_mod}.orig"
    fi
    unxz -c "${amdgpu_mod}.orig" > "$orig_ko"
    echo "  Extracted: $(ls -lh "$orig_ko" | awk '{print $5}')"

    # 2. Binary-patch QP tables and RC offset
    # This approach preserves the exact module binary structure (struct module,
    # BTF, modversions) avoiding the struct mismatch issues of source rebuilds.
    echo "[2/4] Binary-patching DSC QP tables..."
    python3 - "$orig_ko" "$patched_ko" << 'PYSCRIPT'
import struct, sys

data = bytearray(open(sys.argv[1], 'rb').read())
bpp_8 = struct.pack('<f', 8.0)
patches = 0

# QP Max: 444_8bpc_max BPP=8 row indices 10-14: {10,11,11,12,13} -> {11,12,13,13,15}
old_max = bpp_8 + struct.pack('<15i', 4,4,5,6,7,7,7,8,9,10,10,11,11,12,13)
new_max = bpp_8 + struct.pack('<15i', 4,4,5,6,7,7,7,8,9,10,11,12,13,13,15)
off = data.find(old_max)
if off >= 0:
    data[off:off+len(new_max)] = new_max
    patches += 1
    print(f'  QP max BPP=8 patched at 0x{off:x}')
else:
    print('  QP max BPP=8: not found (already patched?)')

# QP Min: 444_8bpc_min BPP=8 row indices 9,13,14: {4,8,12} -> {3,7,13}
old_min = bpp_8 + struct.pack('<15i', 0,0,1,1,3,3,3,3,3,4,5,5,5,8,12)
new_min = bpp_8 + struct.pack('<15i', 0,0,1,1,3,3,3,3,3,3,5,5,5,7,13)
off = data.find(old_min)
if off >= 0:
    data[off:off+len(new_min)] = new_min
    patches += 1
    print(f'  QP min BPP=8 patched at 0x{off:x}')
else:
    print('  QP min BPP=8: not found (already patched?)')

# RC offset: ofs[10] = -10 -> -12 in get_ofs_set()
# Patch movl $0xfffffff6, 0x28(%rax/rdi) -> movl $0xfffffff4, 0x28(%rax/rdi)
# within the get_ofs_set function (find via nm)
import subprocess
nm = subprocess.run(['nm', sys.argv[1]], capture_output=True, text=True)
func_addr = None
for line in nm.stdout.split('\n'):
    if ' t get_ofs_set' in line and '__pfx' not in line:
        func_addr = int(line.split()[0], 16)
        break

if func_addr:
    # Convert vaddr to file offset using readelf
    elf = subprocess.run(['readelf', '-S', sys.argv[1]], capture_output=True, text=True)
    text_addr = text_off = 0
    for line in elf.stdout.split('\n'):
        if '.text' in line and 'PROGBITS' in line:
            parts = line.split()
            for i, p in enumerate(parts):
                if p == 'PROGBITS':
                    text_addr = int(parts[i+1], 16)
                    text_off = int(parts[i+2], 16)
                    break
            break
    func_file_off = func_addr - text_addr + text_off
    func_end = func_file_off + 2000

    rc_count = 0
    # ofs[11] is at offset 0x2c (11*4=44) from the qp_set base pointer.
    # The compiler may use various register forms for the store.
    # Pattern: movl $-10, 0x2c(%reg) → movl $-12, 0x2c(%reg)
    for pattern, replacement, desc in [
        (b'\xc7\x40\x2c\xf6\xff\xff\xff', b'\xc7\x40\x2c\xf4\xff\xff\xff', 'movl 0x2c(%rax)'),
        (b'\xc7\x47\x2c\xf6\xff\xff\xff', b'\xc7\x47\x2c\xf4\xff\xff\xff', 'movl 0x2c(%rdi)'),
        (b'\xc7\x41\x2c\xf6\xff\xff\xff', b'\xc7\x41\x2c\xf4\xff\xff\xff', 'movl 0x2c(%rcx)'),
        (b'\xc7\x42\x2c\xf6\xff\xff\xff', b'\xc7\x42\x2c\xf4\xff\xff\xff', 'movl 0x2c(%rdx)'),
        (b'\xc7\x43\x2c\xf6\xff\xff\xff', b'\xc7\x43\x2c\xf4\xff\xff\xff', 'movl 0x2c(%rbx)'),
        (b'\xc7\x46\x2c\xf6\xff\xff\xff', b'\xc7\x46\x2c\xf4\xff\xff\xff', 'movl 0x2c(%rsi)'),
    ]:
        pos = func_file_off
        while pos < func_end:
            pos = data.find(pattern, pos)
            if pos == -1 or pos >= func_end: break
            print(f'  Patching {desc} -10 -> -12 at file 0x{pos:x}')
            data[pos:pos+len(pattern)] = replacement
            rc_count += 1
            pos += len(pattern)
    if rc_count:
        patches += 1
        print(f'  RC offset: patched {rc_count} ofs[11] stores in get_ofs_set')
else:
    print('  RC offset: get_ofs_set not found in symbol table')

# BPP limit: cap dsc_policy_max_target_bpp_limit from 16 -> 8
# This forces DSC to use 8.0 BPP (128 in x16) matching Beyond EDID target.
# Without this, kernel computes highest BPP that fits link bandwidth (16.0 at 4 lanes).
import subprocess as sp2
nm2 = sp2.run(['nm', sys.argv[1]], capture_output=True, text=True)
bpp_var_addr = None
for line in nm2.stdout.split('\n'):
    if 'dsc_policy_max_target_bpp_limit' in line and '__pfx' not in line and 'set_max' not in line:
        bpp_var_addr = int(line.split()[0], 16)
        break

if bpp_var_addr:
    elf2 = sp2.run(['readelf', '-S', sys.argv[1]], capture_output=True, text=True)
    d_addr = d_off = 0
    for line in elf2.stdout.split('\n'):
        if '.data' in line and 'PROGBITS' in line and '.rela.data' not in line and '.rodata' not in line:
            parts = line.split()
            for i, p in enumerate(parts):
                if p == 'PROGBITS':
                    d_addr = int(parts[i+1], 16)
                    d_off = int(parts[i+2], 16)
                    break
            break
    bpp_file_off = bpp_var_addr - d_addr + d_off
    old_limit = struct.unpack_from('<I', data, bpp_file_off)[0]
    if old_limit != 8:
        struct.pack_into('<I', data, bpp_file_off, 8)
        patches += 1
        print(f'  BPP limit: {old_limit} -> 8 at file offset 0x{bpp_file_off:x}')
    else:
        print('  BPP limit: already set to 8')
else:
    print('  BPP limit: dsc_policy_max_target_bpp_limit not found')

open(sys.argv[2], 'wb').write(bytes(data))
print(f'  Total: {patches} patch groups applied')
PYSCRIPT
    if [ $? -ne 0 ]; then
        echo "ERROR: Binary patching failed"
        exit 1
    fi

    # 3. Verify struct module size unchanged
    echo "[3/4] Verifying module integrity..."
    local orig_size patched_size
    orig_size=$(readelf -s "$orig_ko" | grep __this_module | awk '{print $3}')
    patched_size=$(readelf -s "$patched_ko" | grep __this_module | awk '{print $3}')
    if [ "$orig_size" != "$patched_size" ]; then
        echo "ERROR: struct module size changed ($orig_size -> $patched_size)"
        exit 1
    fi
    echo "  struct module: $patched_size bytes (unchanged)"

    # 4. Install
    echo "[4/4] Installing patched module..."
    xz -c "$patched_ko" > "$amdgpu_mod"
    depmod -a
    echo "  Installed and depmod updated"

    # Done
    echo "Done."
    echo
    echo "  Reboot to load the patched module."
    echo "  To restore original: cp ${amdgpu_mod}.orig ${amdgpu_mod} && depmod -a"
}

cmd_kernel_build() {
    _need_root
    local kver="${1:-$(uname -r | sed 's/-.*//')}"
    echo "=== XR Kernel Build ==="
    echo "  Target kernel: $kver"
    echo "  Patches: bigscreen-beyond-edid + amd-bsb-dsc-fix"
    echo

    # Prerequisites
    echo "[1/6] Checking build dependencies..."
    local missing=""
    for pkg in gcc make elfutils-libelf-devel openssl-devel perl bc bison flex rsync; do
        rpm -q "$pkg" >/dev/null 2>&1 || missing="$missing $pkg"
    done
    if [ -n "$missing" ]; then
        echo "  Installing:$missing"
        dnf install -y $missing
    else
        echo "  All build dependencies present"
    fi

    # Kernel source
    local srcdir="/usr/src/kernels/xr-${kver}"
    echo
    echo "[2/6] Preparing kernel source..."
    if [ -d "$srcdir" ]; then
        echo "  Using existing source: $srcdir"
    else
        # Try ELRepo SRPM first
        local srpm
        srpm=$(find /root/rpmbuild/SRPMS/ -name "kernel-ml-${kver}*.src.rpm" 2>/dev/null | head -1)
        if [ -z "$srpm" ]; then
            echo "  Downloading kernel source..."
            local major_ver="${kver%%.*}"
            curl -Lo "/tmp/linux-${kver}.tar.xz" \
                "https://cdn.kernel.org/pub/linux/kernel/v${major_ver}.x/linux-${kver}.tar.xz"
            mkdir -p "$srcdir"
            tar -xf "/tmp/linux-${kver}.tar.xz" -C "$srcdir" --strip-components=1
        else
            echo "  Extracting from SRPM: $srpm"
            rpm -i "$srpm" 2>/dev/null
            local tarball
            tarball=$(find /root/rpmbuild/SOURCES/ -name "linux-${kver}*.tar*" | head -1)
            mkdir -p "$srcdir"
            tar -xf "$tarball" -C "$srcdir" --strip-components=1
        fi
    fi

    # Apply patches
    echo
    echo "[3/6] Applying XR patches..."
    cd "$srcdir"
    local patch_dir="/tmp"
    # 0007-vesa-dsc-bpp.patch is the CachyOS combined patch (supersedes amd-bsb-dsc-fix.patch).
    # It includes: QP tables + RC ofs[11] + VESA DisplayID DSC BPP parser + amdgpu_dm integration.
    for patch_name in bigscreen-beyond-edid.patch 0007-vesa-dsc-bpp.patch; do
        if [ -f "${patch_dir}/${patch_name}" ]; then
            if patch -p1 --dry-run -N < "${patch_dir}/${patch_name}" >/dev/null 2>&1; then
                patch -p1 -N < "${patch_dir}/${patch_name}"
                echo "  Applied: $patch_name"
            else
                echo "  Skipped (already applied or conflict): $patch_name"
            fi
        else
            echo "  WARNING: $patch_name not found in $patch_dir"
        fi
    done

    # Configure
    echo
    echo "[4/6] Configuring kernel..."
    if [ -f "/boot/config-$(uname -r)" ]; then
        cp "/boot/config-$(uname -r)" .config
        echo "  Base config from running kernel"
    fi

    # XR-specific options
    scripts/config --enable CONFIG_DRM_AMD_DC_DSC
    scripts/config --set-val CONFIG_HZ 1000
    scripts/config --enable CONFIG_HZ_1000
    scripts/config --disable CONFIG_HZ_250
    scripts/config --enable CONFIG_USB_HIDDEV
    scripts/config --enable CONFIG_USB_VIDEO_CLASS
    scripts/config --set-str CONFIG_LOCALVERSION "-xr"
    make olddefconfig
    echo "  XR config applied"

    # Build
    echo
    echo "[5/6] Building kernel (this takes a while)..."
    local jobs
    jobs=$(nproc)
    echo "  Using $jobs parallel jobs"
    make -j"$jobs" bzImage modules 2>&1 | tail -5

    # Install
    echo
    echo "[6/6] Installing..."
    make modules_install
    make install
    depmod -a "${kver}-xr"
    echo "  Installed kernel ${kver}-xr"

    echo
    echo "=== Build complete ==="
    echo "  Reboot to use the new kernel."
    echo "  grubby --set-default /boot/vmlinuz-${kver}-xr"
}

cmd_beyond_display_init() {
    _need_root
    echo "=== Beyond Display Init ==="
    echo "  Sets DSC BPP override, link rate, and sends panel init HID commands"
    echo

    # Find the AMD GPU's debugfs connector for DP-2 (Beyond)
    local debugfs=""
    for d in /sys/kernel/debug/dri/*/DP-2; do
        if [ -d "$d" ]; then
            debugfs="$d"
            break
        fi
    done

    if [ -z "$debugfs" ]; then
        echo "ERROR: No DP-2 connector found in debugfs"
        echo "  Available connectors:"
        ls -d /sys/kernel/debug/dri/*/DP-* 2>/dev/null || echo "  (none)"
        exit 1
    fi
    echo "  Connector: $debugfs"

    # Step 1: DSC BPP override — Beyond requires exactly 8.0 BPP (128 in 1/16th)
    echo
    echo "[1/4] Setting DSC BPP to 128 (8.0 BPP)..."
    if [ -f "$debugfs/dsc_bits_per_pixel" ]; then
        echo "  Current: $(cat "$debugfs/dsc_bits_per_pixel")"
        echo 0x80 > "$debugfs/dsc_bits_per_pixel"
        echo "  Set to: $(cat "$debugfs/dsc_bits_per_pixel")"
    else
        echo "  WARNING: dsc_bits_per_pixel not found (kernel may not support DSC override)"
    fi

    # Step 2: Force HBR2 link rate (5.4 Gbps, 4 lanes)
    echo
    echo "[2/4] Setting link rate to HBR2 (4 lanes, 5.4 Gbps)..."
    if [ -f "$debugfs/link_settings" ]; then
        echo "4 0x14" > "$debugfs/link_settings"
        echo "  Done"
    else
        echo "  WARNING: link_settings not found"
    fi

    # Step 3: Verify DTN (display pipeline state)
    echo
    echo "[3/4] Checking display pipeline..."
    local dtn_dir
    dtn_dir=$(dirname "$debugfs")
    if [ -f "$dtn_dir/amdgpu_dm_dtn_log" ]; then
        # Check DSC and link status
        local dsc_line
        dsc_line=$(grep "DSC" "$dtn_dir/amdgpu_dm_dtn_log" 2>/dev/null | head -3)
        if [ -n "$dsc_line" ]; then
            echo "  DSC status:"
            echo "$dsc_line" | sed 's/^/    /'
        fi
        local fec_line
        fec_line=$(grep "FEC" "$dtn_dir/amdgpu_dm_dtn_log" 2>/dev/null | head -3)
        if [ -n "$fec_line" ]; then
            echo "  FEC status:"
            echo "$fec_line" | sed 's/^/    /'
        fi
    fi

    # Step 4: HID panel init
    echo
    echo "[4/4] Sending HID panel init commands..."
    local user
    user=$(_check_user)

    # The panel init script must run as the actual user (for USB access)
    # or as root. Write an inline Python script.
    /usr/bin/python3 - << 'INITPY'
"""Beyond panel init: OnHidOpen handshake + poll video_state + backlight + unmute."""
import struct, sys, time

try:
    import usb.core, usb.util
except ImportError:
    print("  ERROR: pyusb not installed. Run: pip3 install pyusb")
    sys.exit(1)

VID, PID, INTF = 0x35bd, 0x0101, 2
RT_SET, RT_GET = 0x21, 0xa1
SET_REPORT, GET_REPORT = 0x09, 0x01
FEATURE = 0x0300

STATES = {0: "DP Init", 1: "MIPI Init", 2: "Wait For Sync",
           3: "Panel Init", 4: "Backlight Init", 5: "Stable",
           6: "Reset", 7: "Delayed", 8: "Disabled", 9: "Invalid"}

dev = usb.core.find(idVendor=VID, idProduct=PID)
if dev is None:
    print("  ERROR: Beyond (35bd:0101) not found on USB")
    sys.exit(1)
print(f"  Found: {dev.product} (bus {dev.bus} dev {dev.address})")

if dev.is_kernel_driver_active(INTF):
    dev.detach_kernel_driver(INTF)
usb.util.claim_interface(dev, INTF)

def set_feat(fid, data):
    buf = bytes([fid]) + data
    buf = buf + b'\x00' * (64 - len(buf))
    dev.ctrl_transfer(RT_SET, SET_REPORT, FEATURE, INTF, buf)

def get_feat(fid, length=64):
    try:
        return bytes(dev.ctrl_transfer(RT_GET, GET_REPORT, FEATURE, INTF, length))
    except Exception:
        return None

# OnHidOpen handshake: FeatureID 0x04 with magic 0x2978
print("  Sending OnHidOpen handshake (FeatureID 0x04, magic 0x2978)...")
payload = bytearray(0x3b)
payload[0:4] = b'\x78\x29\x38\x01'
set_feat(0x04, bytes(payload))
time.sleep(0.1)
resp = get_feat(0x04)
if resp:
    print(f"  Response: {resp[:16].hex()}")

# SetVideoConfig: enable DP training (FeatureID 0x26)
print("  Sending SetVideoConfig (FeatureID 0x26, dp_training=1)...")
vc = bytearray(0x3f)
vc[2] = 1  # dp_training_enable
set_feat(0x26, bytes(vc))
time.sleep(0.5)

# Poll video_state via FeatureID 0x15
print("  Polling video_state (timeout 45s)...")
start = time.time()
last = -1
stable = False
while time.time() - start < 45:
    set_feat(0x15, b'\x00' * 0x3f)
    time.sleep(0.05)
    r = get_feat(0x15)
    if r and len(r) > 1:
        st = r[1]
        if st != last:
            print(f"    state={st} ({STATES.get(st, '?')}) @ {time.time()-start:.1f}s")
            last = st
        if st == 5:
            stable = True
            break
    time.sleep(0.2)

if not stable:
    print(f"  WARNING: Did not reach Stable (last: {STATES.get(last, last)})")
    print("  Sending backlight/unmute anyway...")

# SetBacklightGain (FeatureID 0x30) — 50% brightness
print("  Setting backlight gain to 0.5...")
set_feat(0x30, struct.pack('<f', 0.5))
time.sleep(0.1)

# SetHMDMuteState (FeatureID 0x25) — unmute
print("  Unmuting display...")
set_feat(0x25, b'\x00\x00\x00\x00')
time.sleep(0.1)

# Read final state
set_feat(0x15, b'\x00' * 0x3f)
time.sleep(0.05)
r = get_feat(0x15)
if r and len(r) > 1:
    print(f"  Final video_state: {r[1]} ({STATES.get(r[1], '?')})")

# Read backlight
set_feat(0x30, b'\x00' * 4)
time.sleep(0.05)
r = get_feat(0x30)
if r and len(r) >= 5:
    bl = struct.unpack_from('<f', r, 1)[0]
    print(f"  Backlight: {bl}")

print("  Panel init complete.")
INITPY
    echo
    echo "=== Display init complete ==="
}

cmd_beyond_monitor() {
    _need_root
    echo "=== Beyond Display Monitor ==="
    echo "  Ctrl-C to stop"
    echo

    local debugfs=""
    for d in /sys/kernel/debug/dri/*/DP-2; do
        [ -d "$d" ] && debugfs="$d" && break
    done
    local dtn_dir
    dtn_dir=$(dirname "$debugfs")

    # Enable CRC capture
    echo auto > "$dtn_dir/crtc-1/crc/control" 2>/dev/null || true

    while true; do
        echo "--- $(date +%H:%M:%S) ---"

        # DSC state
        local dsc_en slice_w bpp
        dsc_en=$(awk '/^\[1\]:/{print $2; exit}' <(sed -n '/^DSC:/,/^$/p' "$dtn_dir/amdgpu_dm_dtn_log") 2>/dev/null)
        slice_w=$(awk '/^\[1\]:/{print $3; exit}' <(sed -n '/^DSC:/,/^$/p' "$dtn_dir/amdgpu_dm_dtn_log") 2>/dev/null)
        bpp=$(cat "$debugfs/dsc_bits_per_pixel" 2>/dev/null | tr -d '\0')
        echo "  DSC: clock_en=$dsc_en slice_w=$slice_w bpp=$bpp"

        # Link status
        local fec_active link_ok
        fec_active=$(awk '/^\[1/{print $4; exit}' <(sed -n '/^L_ENC: DPHY/,/^$/p' "$dtn_dir/amdgpu_dm_dtn_log") 2>/dev/null)
        link_ok=$(awk '/^\[1/{print $5; exit}' <(sed -n '/^L_ENC: DPHY/,/^$/p' "$dtn_dir/amdgpu_dm_dtn_log") 2>/dev/null)
        echo "  Link: fec_active=$fec_active training_complete=$link_ok"

        # CRC (frame counter + hash)
        local crc_line
        crc_line=$(timeout 1 head -1 "$dtn_dir/crtc-1/crc/data" 2>/dev/null)
        if [ -n "$crc_line" ]; then
            echo "  CRC: $crc_line"
        else
            echo "  CRC: (no data)"
        fi

        # Monado process
        local mpid
        mpid=$(pgrep -o monado-service 2>/dev/null || echo "DEAD")
        echo "  Monado: PID=$mpid"

        # HID input report (one read, check type)
        /usr/bin/python3 -c "
import os, select, time
try:
    fd = os.open('/dev/hidraw3', os.O_RDONLY | os.O_NONBLOCK)
    r, _, _ = select.select([fd], [], [], 0.3)
    if r:
        data = os.read(fd, 64)
        t = data[0] if data else 0
        if t == 0x23:
            # IMU: bytes 1-4 = timestamp, 5-6 = accel/gyro ranges
            ts = int.from_bytes(data[1:5], 'little')
            print(f'  HID: type=0x23(IMU) ts={ts} len={len(data)}')
        elif t == 0x24:
            print(f'  HID: type=0x24(STATUS) data={data[:16].hex()}')
        else:
            print(f'  HID: type=0x{t:02x} data={data[:16].hex()}')
    else:
        print('  HID: (no report)')
    os.close(fd)
except Exception as e:
    print(f'  HID: error={e}')
" 2>/dev/null

        # Underflow check
        local uf
        uf=$(awk '/^\[ 1\]:/{print $13; exit}' <(sed -n '/^HUBP:  format/,/^$/p' "$dtn_dir/amdgpu_dm_dtn_log") 2>/dev/null)
        [ "$uf" != "0h" ] && [ -n "$uf" ] && echo "  !! UNDERFLOW: $uf"

        echo
        sleep 2
    done
}

cmd_beyond_dsc_flash() {
    _need_root
    echo "=== Beyond DSC Flash Trigger ==="
    echo "  Toggles DSC off/on to trigger FPGA re-init (flash canary)"
    echo "  PUT HEADSET ON before running this!"
    echo

    local debugfs=""
    for d in /sys/kernel/debug/dri/*/DP-2; do
        [ -d "$d" ] && debugfs="$d" && break
    done

    if [ -z "$debugfs" ]; then
        echo "ERROR: DP-2 debugfs not found"
        exit 1
    fi

    echo "[1] Current DSC BPP: $(cat "$debugfs/dsc_bits_per_pixel" 2>/dev/null | tr -d '\0')"

    # Force a link retrain by writing link_settings
    # This causes the FPGA to re-detect the DP stream
    echo "[2] Forcing link retrain (HBR2, 4 lanes)..."
    echo "4 0x14" > "$debugfs/link_settings"
    sleep 1

    echo "[3] Post-retrain DSC BPP: $(cat "$debugfs/dsc_bits_per_pixel" 2>/dev/null | tr -d '\0')"

    # Check DSC state
    local dtn_dir
    dtn_dir=$(dirname "$debugfs")
    echo "[4] DSC state after retrain:"
    sed -n '/^DSC:/,/^$/p' "$dtn_dir/amdgpu_dm_dtn_log" 2>/dev/null | head -6

    echo
    echo "Did you see a flash? If yes, the FPGA is decoding (partially)."
    echo "If no flash, the FPGA is not detecting the DP stream change."
}

cmd_beyond_dsc_sweep() {
    _need_root
    echo "=== Beyond DSC BPP Sweep ==="
    echo "  Tries different DSC BPP values to find what the FPGA accepts"
    echo "  PUT HEADSET ON before running this!"
    echo

    local debugfs=""
    for d in /sys/kernel/debug/dri/*/DP-2; do
        [ -d "$d" ] && debugfs="$d" && break
    done

    if [ -z "$debugfs" ]; then
        echo "ERROR: DP-2 debugfs not found"
        exit 1
    fi

    # Kill and restart Monado for each BPP value
    # BPP values to try (in 1/16th): 128=8.0, 96=6.0, 160=10.0, 112=7.0, 144=9.0
    for bpp in 128 96 160 112 144; do
        local bpp_real
        bpp_real=$(echo "scale=1; $bpp / 16" | bc)
        echo "--- Testing BPP=$bpp ($bpp_real bpp) ---"

        # Kill Monado
        pkill -f monado-service 2>/dev/null || true
        sleep 2
        rm -f /run/user/1000/monado_comp_ipc

        # Set BPP override
        echo "$bpp" > "$debugfs/dsc_bits_per_pixel"
        echo "  Set override: $(cat "$debugfs/dsc_bits_per_pixel" 2>/dev/null | tr -d '\0')"

        # Start Monado
        local user
        user=$(_check_user)
        sudo -u "$user" bash -c "
            export XDG_RUNTIME_DIR=/run/user/1000
            export WAYLAND_DISPLAY=wayland-1
            export STEAMVR_LH_ENABLE=1
            (while true; do sleep 86400; done) | /usr/local/bin/monado-service > /tmp/monado-sweep-$bpp.log 2>&1 &
        "
        sleep 5

        if pgrep -q monado-service 2>/dev/null; then
            echo "  Monado started"
            echo "  >>> Put headset on NOW — watching for 8 seconds..."
            sleep 8

            # Check CRC (are frames different?)
            local dtn_dir
            dtn_dir=$(dirname "$debugfs")
            echo auto > "$dtn_dir/crtc-1/crc/control" 2>/dev/null || true
            local crc1 crc2
            crc1=$(timeout 1 head -1 "$dtn_dir/crtc-1/crc/data" 2>/dev/null)
            sleep 0.5
            crc2=$(timeout 1 head -1 "$dtn_dir/crtc-1/crc/data" 2>/dev/null)
            echo "  CRC: $crc1"
        else
            echo "  Monado FAILED to start at BPP=$bpp"
            tail -3 "/tmp/monado-sweep-$bpp.log" 2>/dev/null
        fi
        echo
    done

    echo "=== Sweep complete ==="
    echo "Which BPP value produced a flash or sustained display?"
}

cmd_full_setup() {
    cmd_prereqs
    echo
    cmd_kernel_upgrade
}

# ── Main ────────────────────────────────────────────────

usage() {
    echo "Usage: exwm-vr-setup <command>"
    echo
    echo "Commands:"
    echo "  prereqs              Install groups, udev rules, check firmware (sudo)"
    echo "  kernel-upgrade       Install ELRepo kernel-ml + firmware (sudo)"
    echo "  sway-setup           Build + install sway host compositor (sudo)"
    echo "  steam-setup          Install native Steam + configure SteamVR (sudo)"
    echo "  monado-setup         Build + install Monado OpenXR runtime (sudo)"
    echo "  verify               Verify display, DRM, USB, permissions"
    echo "  beyond-status        Quick Beyond 2e status"
    echo "  beyond-hid-test      Test HID device access"
    echo "  beyond-power-on      Send HID power-on sequence to Beyond display"
    echo "  beyond-first-frame   Test full pipeline: power-on → Monado → hello_xr"
    echo "  beyond-download-config  Download Beyond calibration via lighthouse_console"
    echo "  beyond-oobe          Full out-of-box experience (power → config → test)"
    echo "  openxr-build         Build hello_xr from OpenXR-SDK-Source"
    echo "  gpu-tools            Install Vulkan tools + GPU diagnostics (sudo)"
    echo "  beyond-display-init  Set DSC BPP + link rate + HID panel init (sudo)"
    echo "  beyond-monitor       Continuous display pipeline monitor (sudo)"
    echo "  beyond-dsc-flash     Toggle DSC to trigger FPGA re-init flash (sudo)"
    echo "  beyond-dsc-sweep     Try multiple DSC BPP values (sudo)"
    echo "  kernel-build [ver]   Build XR kernel from source with all patches (sudo)"
    echo "  kernel-dsc-fix       Patch amdgpu DSC QP tables for Beyond (sudo)"
    echo "  full-setup           Run prereqs + kernel-upgrade (sudo)"
    echo
    echo "Environment:"
    echo "  EXWM_USER        Override target user (default: \$SUDO_USER or \$USER)"
}

case "${1:-}" in
    prereqs)        shift; cmd_prereqs "$@" ;;
    kernel-upgrade) shift; cmd_kernel_upgrade "$@" ;;
    verify)         shift; cmd_verify "$@" ;;
    beyond-status)  shift; cmd_beyond_status "$@" ;;
    beyond-hid-test) shift; cmd_beyond_hid_test "$@" ;;
    sway-setup)     shift; cmd_sway_setup "$@" ;;
    steam-setup)    shift; cmd_steam_setup "$@" ;;
    monado-setup)   shift; cmd_monado_setup "$@" ;;
    beyond-power-on) shift; cmd_beyond_power_on "$@" ;;
    beyond-first-frame) shift; cmd_beyond_first_frame "$@" ;;
    beyond-download-config) shift; cmd_beyond_download_config "$@" ;;
    beyond-oobe)    shift; cmd_beyond_oobe "$@" ;;
    openxr-build)   shift; cmd_openxr_build "$@" ;;
    gpu-tools)      shift; cmd_gpu_tools "$@" ;;
    beyond-display-init) shift; cmd_beyond_display_init "$@" ;;
    beyond-monitor) shift; cmd_beyond_monitor "$@" ;;
    beyond-dsc-flash) shift; cmd_beyond_dsc_flash "$@" ;;
    beyond-dsc-sweep) shift; cmd_beyond_dsc_sweep "$@" ;;
    kernel-build)   shift; cmd_kernel_build "$@" ;;
    kernel-dsc-fix) shift; cmd_kernel_dsc_fix "$@" ;;
    full-setup)     shift; cmd_full_setup "$@" ;;
    -h|--help|help) usage ;;
    *)
        echo "Unknown command: ${1:-}"
        usage
        exit 1
        ;;
esac
